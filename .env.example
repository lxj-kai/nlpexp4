# ===== Deepseek API =====
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== Experiment =====
NLP4_DATA_DIR=data/rgb
NLP4_RESULTS_DIR=experiments/results
NLP4_CACHE_DIR=.cache
NLP4_SEED=42

# ===== Backend / API =====
# 后端 CORS allow_origins，逗号分隔；留空默认只放 localhost:5173/4173。
# 生产部署若要开公网，显式列出域名，例如：
# NLP4_ALLOW_ORIGINS=https://yourapp.example.com,https://www.example.com
NLP4_ALLOW_ORIGINS=
